{
  "name": "@7ito/sketcherson-common",
  "version": "0.3.6",
  "description": "Shared engine, game definition, room, drawing, and Vite utilities for Sketcherson games.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./game": {
      "types": "./dist/game.d.ts",
      "default": "./dist/game.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./gamePack": {
      "types": "./dist/gamePack.d.ts",
      "default": "./dist/gamePack.js"
    },
    "./gameRuntime": {
      "types": "./dist/gameRuntime.d.ts",
      "default": "./dist/gameRuntime.js"
    },
    "./gameAuthoring": {
      "types": "./dist/gameAuthoring.d.ts",
      "default": "./dist/gameAuthoring.js"
    },
    "./gameDefinition": {
      "types": "./dist/gameDefinition.d.ts",
      "default": "./dist/gameDefinition.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "default": "./dist/prompts.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "default": "./dist/settings.js"
    },
    "./room": {
      "types": "./dist/room.d.ts",
      "default": "./dist/room.js"
    },
    "./roomEvents": {
      "types": "./dist/roomEvents.d.ts",
      "default": "./dist/roomEvents.js"
    },
    "./drawing": {
      "types": "./dist/drawing.d.ts",
      "default": "./dist/drawing.js"
    },
    "./drawingProtocol": {
      "types": "./dist/drawingProtocol.d.ts",
      "default": "./dist/drawingProtocol.js"
    },
    "./drawingRealtime": {
      "types": "./dist/drawingRealtime.d.ts",
      "default": "./dist/drawingRealtime.js"
    },
    "./drawingRaster": {
      "types": "./dist/drawingRaster.d.ts",
      "default": "./dist/drawingRaster.js"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "default": "./dist/identity.js"
    },
    "./moderation": {
      "types": "./dist/moderation.d.ts",
      "default": "./dist/moderation.js"
    },
    "./scoring": {
      "types": "./dist/scoring.d.ts",
      "default": "./dist/scoring.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./testing/testGame": {
      "types": "./dist/games/testGame/index.d.ts",
      "default": "./dist/games/testGame/index.js"
    },
    "./games/testGame": {
      "types": "./dist/games/testGame/index.d.ts",
      "default": "./dist/games/testGame/index.js"
    }
  },
  "scripts": {
    "build": "tsup && npm run validate:exports",
    "test": "vitest run --passWithNoTests",
    "validate:exports": "node scripts/validate-exports.mjs"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
